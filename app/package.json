{
  "name": "ledgi-mobile",
  "main": "expo/AppEntry",
  "version": "1.0.0",
  "scripts": {
    "start": "NODE_OPTIONS=\"--require ./scripts/force-ipv4.js\" expo start",
    "start:tunnel": "NODE_OPTIONS=\"--require ./scripts/force-ipv4.js\" expo start --tunnel",
    "start:usb": "adb reverse tcp:8081 tcp:8081 && NODE_OPTIONS=\"--require ./scripts/force-ipv4.js\" expo start --localhost",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "NODE_OPTIONS=\"--require ./scripts/force-ipv4.js\" expo start --android",
    "ios": "NODE_OPTIONS=\"--require ./scripts/force-ipv4.js\" expo start --ios",
    "web": "NODE_OPTIONS=\"--require ./scripts/force-ipv4.js\" expo start --web",
    "lint": "expo lint",
    "test": "jest --watchAll=false",
    "test:watch": "jest --watchAll",
    "test:coverage": "jest --coverage --watchAll=false",
    "typecheck": "tsc --noEmit",
    "expo:login": "NODE_OPTIONS=\"--require ./scripts/force-ipv4.js\" npx expo login"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-picker/picker": "2.11.1",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@react-navigation/native-stack": "^7.2.0",
    "@tanstack/react-query": "^5.62.7",
    "expo": "~54.0.33",
    "expo-asset": "~12.0.13",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "firebase": "^10.14.1",
    "lodash.debounce": "^4.0.8",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-toast-message": "^2.2.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@expo/ngrok": "^4.1.3",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.9.0",
    "@types/jest": "^29.5.14",
    "@types/lodash.debounce": "^4.0.9",
    "@types/node": "^25.6.0",
    "@types/react": "~19.1.0",
    "@types/react-test-renderer": "^19.0.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "react-test-renderer": "19.0.0",
    "typescript": "~5.9.2"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [],
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.ts"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|@tanstack/.*|firebase/.*|@firebase/.*)"
    ],
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/**/*.d.ts"
    ]
  },
  "private": true
}
