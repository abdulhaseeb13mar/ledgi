{
  "expo": {
    "name": "Ledgi",
    "slug": "ledgi-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#01017e"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ledgi.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#01017e"
      },
      "package": "com.ledgi.mobile"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-router"],
    "scheme": "ledgi",
    "extra": {
      "eas": {
        "projectId": "ledgi-mobile"
      }
    }
  }
}
